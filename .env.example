# Application Configurations
APP_NAME="YouTube Migrator"
DEBUG=true
PORT=8000
HOST="127.0.0.1"

# Database Configuration
DATABASE_URL="sqlite:///database/youtube_migrator.db"

# Storage Directories (absolute or relative to project root)
DOWNLOADS_DIR="downloads"
TOKENS_DIR="tokens"
LOGS_DIR="logs"

# OAuth 2.0 Credentials (From Google Cloud Console)
# Client ID and Secret can be directly set here, or point to a client_secret.json file
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/callback"
GOOGLE_CLIENT_SECRETS_FILE="client_secret.json"
